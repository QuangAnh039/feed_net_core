config PACKAGE_tr181-dhcpv4relay
    tristate
    select SAH_TR181_DHCPV4RELAY

if PACKAGE_tr181-dhcpv4relay

menu "Select tr181-dhcpv4relay build options"
    depends on PACKAGE_tr181-dhcpv4relay

config SAH_TR181_DHCPV4RELAY
    bool "Build a tr181 compatible dhcpv4 relay plugin"
    default y

config SAH_TR181_DHCPV4RELAY_RUN_AS_USER
    string "User will be used for the tr181-dhcpv4relay plugin"
    default "tr181_app"

config SAH_TR181_DHCPV4RELAY_RUN_AS_GROUP
    string "Group will be used for the tr181-dhcpv4relay plugin"
    default "tr181_app"

endmenu

endif
