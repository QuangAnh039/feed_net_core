config PACKAGE_tr181-dhcpv6client
    tristate
    select SAH_AMX_TR181_DHCPV6CLIENT

if PACKAGE_tr181-dhcpv6client

menu "Select tr181-dhcpv6client build options"
    depends on PACKAGE_tr181-dhcpv6client

config SAH_AMX_TR181_DHCPV6CLIENT
    bool "Build TR-181 compatible DHCPv6 client"
    default y

config SAH_AMX_TR181_DHCPV6CLIENT_RUN_AS_USER
    string "User will be used for the tr181-dhcpv6client plugin"
    default "tr181_app"

config SAH_AMX_TR181_DHCPV6CLIENT_RUN_AS_GROUP
    string "Group will be used for the tr181-dhcpv6client plugin"
    default "tr181_app"

endmenu

endif
